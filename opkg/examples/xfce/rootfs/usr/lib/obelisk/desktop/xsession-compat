#!/bin/sh
# Obelisk generic X session wrapper for display managers.

echo "[xsession-compat] start"

if [ -x /usr/bin/xfce4-session ]; then
  echo "[xsession-compat] exec /usr/bin/xfce4-session"
  exec /usr/bin/xfce4-session
fi
if [ -x /bin/xfce4-session ]; then
  echo "[xsession-compat] exec /bin/xfce4-session"
  exec /bin/xfce4-session
fi
if [ -f /usr/bin/startxfce4 ]; then
  echo "[xsession-compat] exec /usr/bin/startxfce4"
  exec /bin/sh /usr/bin/startxfce4
fi
if [ -f /bin/startxfce4 ]; then
  echo "[xsession-compat] exec /bin/startxfce4"
  exec /bin/sh /bin/startxfce4
fi
if [ -f /usr/lib/obelisk/desktop/startxfce4-compat ]; then
  echo "[xsession-compat] exec startxfce4-compat"
  exec /bin/sh /usr/lib/obelisk/desktop/startxfce4-compat
fi

echo "xsession-compat: no XFCE launcher available"
echo "xsession-compat: install real XFCE/XDM runtime packages for GUI session startup"
exit 1
